# PostHog project token + host for product analytics. When unset, the
# app renders identically without telemetry — instrumentation-client.ts
# skips posthog.init. Project tokens (phc_*) are safe to expose in the
# client; PostHog treats them as public.
# NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
